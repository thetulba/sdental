rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - role: string (admin, receptionist, accountant, doctor)
    // - email: string
    //
    // Collection: patients
    // - firstName, lastName, phone, etc.
    //
    // Collection: payments
    // - amount, type, patientId, etc.
    //
    // Collection: invoices
    // - total, patientId, etc.
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('owner') || (request.auth.token.email == "the.tulba@gmail.com" && request.auth.token.email_verified == true);
    }

    function isAccountant() {
      return hasRole('accountant') || isAdmin();
    }

    function isReceptionist() {
      return hasRole('receptionist') || isAdmin();
    }

    function isDoctor() {
      return hasRole('doctor') || isAdmin();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
