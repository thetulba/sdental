rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - role: string (admin, receptionist, accountant, doctor)
    // - email: string
    //
    // Collection: patients
    // - firstName, lastName, phone, etc.
    //
    // Collection: payments
    // - amount, type, patientId, etc.
    //
    // Collection: invoices
    // - total, patientId, etc.
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('owner') || (request.auth.token.email == "the.tulba@gmail.com" && request.auth.token.email_verified == true);
    }

    function isAccountant() {
      return hasRole('accountant') || isAdmin();
    }

    function isReceptionist() {
      return hasRole('receptionist') || isAdmin();
    }

    function isDoctor() {
      return hasRole('doctor') || isAdmin();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /experts/{expertId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && request.resource.data.keys().hasAll(['name', 'role', 'description', 'order']) &&
                      request.resource.data.name is string && request.resource.data.name.size() < 100 &&
                      request.resource.data.role is string && request.resource.data.role.size() < 100 &&
                      request.resource.data.description is string && request.resource.data.description.size() < 1000 &&
                      request.resource.data.order is number;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isDoctor() || isAdmin();
    }

    match /portfolio/{caseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow create, update: if isReceptionist() || isDoctor();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAccountant();
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create, update: if isAccountant();
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create, update: if isReceptionist() || isDoctor();
      allow delete: if isAdmin();
    }

    match /backups/{backupId} {
      allow read, write: if isAdmin();
    }

    match /promocodes/{code} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
