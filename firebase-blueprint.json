{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "System user with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "receptionist", "accountant", "doctor", "owner"] },
        "branch": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "xrays": { "type": "array", "items": { "type": "object" } },
        "gallery": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["uid", "email", "role"]
    },
    "PortfolioCase": {
      "title": "Portfolio Case",
      "description": "A clinical case for the public portfolio.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "image": { "type": "string", "description": "Base64 or URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "image"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient demographic and clinical metadata.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "patientId": { "type": "string", "description": "Custom or internal ID" },
        "internalId": { "type": "string" },
        "phone": { "type": "string" },
        "secondaryPhone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "insuranceCompany": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "maritalStatus": { "type": "string" },
        "memberNumber": { "type": "string" },
        "groupNumber": { "type": "string" },
        "crtNumber": { "type": "string" },
        "isInsured": { "type": "boolean" },
        "insuranceLimit": { "type": "number" },
        "approvalRequired": { "type": "boolean" },
        "insurancePercentage": { "type": "number" },
        "insuranceExpiry": { "type": "string", "format": "date" },
        "nationality": { "type": "string" },
        "country": { "type": "string" },
        "address": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "details": { "type": "string" },
        "emergencyContact": { "type": "string" },
        "referral": { "type": "string" },
        "doctor": { "type": "string" },
        "branch": { "type": "string" },
        "priceListGroup": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "pending", "disabled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "totalPayments": { "type": "number" },
        "remainingBalance": { "type": "number" },
        "balance": { "type": "number" }
      },
      "required": ["firstName", "lastName", "phone"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Financial transaction record.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["cash", "card", "bank_transfer", "mobile_wallet"] },
        "balance": { "type": "number" },
        "isClaimed": { "type": "boolean" },
        "isSigned": { "type": "boolean" },
        "isRefunded": { "type": "boolean" },
        "details": { "type": "string" },
        "insuranceCompany": { "type": "string" },
        "invoiceId": { "type": "string" },
        "branch": { "type": "string" },
        "doctor": { "type": "string" },
        "appointmentId": { "type": "string" },
        "refundDate": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "amount", "type"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Billing document for procedures.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "invoiceId": { "type": "string" },
        "procedures": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "tax": { "type": "number" },
        "taxPercent": { "type": "number" },
        "discount": { "type": "number" },
        "discountPercent": { "type": "number" },
        "diagnosticFees": { "type": "number" },
        "subtotal": { "type": "number" },
        "insuranceShare": { "type": "number" },
        "patientShare": { "type": "number" },
        "requiredToPay": { "type": "number" },
        "paid": { "type": "number" },
        "isPaidInFull": { "type": "boolean" },
        "isSigned": { "type": "boolean" },
        "isReleased": { "type": "boolean" },
        "releasedAt": { "type": "string", "format": "date-time" },
        "branch": { "type": "string" },
        "doctor": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "total"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled clinical visit.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "canceled", "no_show"] },
        "room": { "type": "string" },
        "doctor": { "type": "string" },
        "branch": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["patientId", "date", "status"]
    },
    "BackupRecord": {
      "title": "Backup Record",
      "description": "Log of data backups.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "size": { "type": "number" },
        "status": { "type": "string" },
        "type": { "type": "string", "enum": ["manual", "scheduled"] },
        "fileUrl": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["timestamp", "status"]
    },
    "PromoCode": {
      "title": "Promo Code",
      "description": "Discount code for patients.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountPercent": { "type": "number" },
        "isActive": { "type": "boolean" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discountPercent", "isActive"]
    },
    "Service": {
      "title": "Service",
      "description": "Dental service offered.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["name", "price"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient records."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment transactions."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Procedural invoices."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Patient appointments."
    },
    "/backups/{backupId}": {
      "schema": "BackupRecord",
      "description": "System backup logs."
    },
    "/portfolio/{caseId}": {
      "schema": "PortfolioCase",
      "description": "Public portfolio cases."
    },
    "/promocodes/{code}": {
      "schema": "PromoCode",
      "description": "Valid promo codes."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Available dental services."
    }
  }
}
